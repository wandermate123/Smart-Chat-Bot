# Meta WhatsApp Cloud API — copy to .env and fill in

META_VERIFY_TOKEN=
META_APP_SECRET=
META_WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Vercel webhook (Meta → either URL; must match what you paste in Meta dashboard):
#   https://YOUR-PROJECT.vercel.app/webhooks/whatsapp
#   https://YOUR-PROJECT.vercel.app/api/webhooks/whatsapp
# Token: paste only the token string, not "Bearer ..." (Bearer is added in code).

# Skip Postgres entirely (SQLite for idempotency + funnel stage only). Use while fixing Supabase/DNS.
# DATABASE_ENABLED=false

# Production: Supabase / Neon — plain postgresql:// is auto-rewritten to postgresql+psycopg://.
#
# Option A — one line (password must be URL-encoded if it contains @ # % ] etc.):
# DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxx.supabase.co:5432/postgres?sslmode=require
#
# Option B — if Option A breaks DNS / host looks like "@]@db....", use separate vars (no encoding):
# DATABASE_HOST=db.xxxxx.supabase.co
# DATABASE_USER=postgres
# DATABASE_PASSWORD=paste-password-here
# DATABASE_NAME=postgres
# DATABASE_PORT=5432
# DATABASE_SSLMODE=require
# (Do not set DATABASE_URL when using Option B, or set it empty — URL wins if non-empty.)
#
# After first DATABASE_URL: run migrations from project root.
# Alembic loads .env automatically, or set DATABASE_URL in the shell:
#   python -m alembic upgrade head
# Then set DATABASE_AUTO_CREATE_TABLES=false on Vercel so only migrations change schema.
# DATABASE_AUTO_CREATE_TABLES=true

# Display only (marketing). Change when you switch numbers in Meta + Vercel PHONE_NUMBER_ID.
MAIN_WHATSAPP_E164=+918400437772

# Optional
WHATSAPP_API_VERSION=v21.0
OUTBOUND_REPLY_ENABLED=true
# Local: ./data/... | Vercel: omit (uses /tmp) or set /tmp/idempotency.db
IDEMPOTENCY_DB_PATH=./data/idempotency.db
LOG_LEVEL=INFO
